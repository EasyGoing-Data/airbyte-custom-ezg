{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$comment": "Raw passthrough: real Google Play columns (verified from actual files) typed as string; cast/transform downstream in dbt. additionalProperties keeps any new column Google adds.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "store_id": {
      "type": [
        "null",
        "string"
      ]
    },
    "app_id": {
      "type": [
        "null",
        "string"
      ]
    },
    "_report_month": {
      "type": [
        "null",
        "string"
      ]
    },
    "_source_file": {
      "type": [
        "null",
        "string"
      ]
    },
    "_row_number": {
      "type": [
        "null",
        "integer"
      ]
    },
    "_file_modified_at": {
      "type": [
        "null",
        "string"
      ],
      "format": "date-time"
    },
    "_synced_at": {
      "type": [
        "null",
        "string"
      ],
      "format": "date-time"
    },
    "Package Name": {
      "type": [
        "null",
        "string"
      ]
    },
    "App Version Code": {
      "type": [
        "null",
        "string"
      ]
    },
    "App Version Name": {
      "type": [
        "null",
        "string"
      ]
    },
    "Reviewer Language": {
      "type": [
        "null",
        "string"
      ]
    },
    "Device": {
      "type": [
        "null",
        "string"
      ]
    },
    "Review Submit Date and Time": {
      "type": [
        "null",
        "string"
      ]
    },
    "Review Submit Millis Since Epoch": {
      "type": [
        "null",
        "string"
      ]
    },
    "Review Last Update Date and Time": {
      "type": [
        "null",
        "string"
      ]
    },
    "Review Last Update Millis Since Epoch": {
      "type": [
        "null",
        "string"
      ]
    },
    "Star Rating": {
      "type": [
        "null",
        "string"
      ]
    },
    "Review Title": {
      "type": [
        "null",
        "string"
      ]
    },
    "Review Text": {
      "type": [
        "null",
        "string"
      ]
