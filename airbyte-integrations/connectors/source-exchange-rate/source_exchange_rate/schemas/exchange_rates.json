{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$comment": "Long shape: 1 dòng = (date, currency) -> rate. Tên cột normalize _Name_ lúc discover (BQ-safe).",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "date":         { "type": ["null", "string"], "format": "date" },
    "base":         { "type": ["null", "string"] },
    "currency":     { "type": ["null", "string"] },
    "rate":         { "type": ["null", "number"] },
    "amount":       { "type": ["null", "number"] },
    "extracted_at": { "type": ["null", "string"], "format": "date-time" },
    "synced_at":    { "type": ["null", "string"], "format": "date-time" }
  }
}
